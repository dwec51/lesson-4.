  /* Tree */
  .node {
    background: #fffdf7;
    border: 1px solid rgba(26,26,26,0.18);
    border-radius: 14px;
    margin-bottom: 12px;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.2s ease;
  }
  .node:active { transform: scale(0.997); }
  .node.open { border-color: rgba(26,26,26,0.4); box-shadow: 0 8px 30px -12px rgba(0,0,0,0.15); }

  .node-head {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 18px;
    cursor: pointer;
    user-select: none;
    position: relative;
  }
  .num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #999;
    letter-spacing: 0.1em;
    flex-shrink: 0;
    width: 32px;
  }
  .title {
    font-size: 19px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    flex: 1;
  }
  .toggle {
    font-family: 'JetBrains Mono', monospace;
    font-size: 18px;
    color: #c45730;
    font-weight: 600;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }
  .node.open .toggle { transform: rotate(45deg); }

  .body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .node.open .body { max-height: 2400px; }
  .body-inner {
    padding: 0 18px 22px 64px;
    font-size: 15.5px;
    line-height: 1.55;
    color: #2a2a2a;
  }
  .body-inner p { margin-bottom: 12px; }
  .body-inner strong { font-weight: 600; color: #1a1a1a; }
  .body-inner em { color: #c45730; font-style: italic; font-weight: 600; }

  .key-box {
    background: #f5f1e8;
    border-left: 3px solid #c45730;
    padding: 12px 14px;
    margin: 14px 0;
    border-radius: 0 8px 8px 0;
    font-size: 14.5px;
  }
  .key-box .label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #c45730;
    margin-bottom: 6px;
    display: block;
  }

  .formula {
    font-family: 'JetBrains Mono', monospace;
    background: #1a1a1a;
    color: #f5f1e8;
    padding: 10px 14px;
    border-radius: 8px;
    text-align: center;
    margin: 12px 0;
    font-size: 14px;
    letter-spacing: 0.05em;
  }

  .sub-list {
    list-style: none;
    margin: 10px 0;
  }
  .sub-list li {
    padding: 8px 0 8px 24px;
    position: relative;
    border-bottom: 1px dashed rgba(26,26,26,0.12);
  }
  .sub-list li:last-child { border-bottom: none; }
  .sub-list li::before {
    content: "→";
    position: absolute;
    left: 0;
