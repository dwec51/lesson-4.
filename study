    border-bottom: 1px solid rgba(26,26,26,0.15);
    margin-bottom: 28px;
  }
  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #c45730;
    margin-bottom: 12px;
  }
  h1 {
    font-size: 34px;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-style: italic;
  }
  h1 em { color: #c45730; font-style: italic; }
  .sub {
    font-size: 14px;
    color: #555;
    margin-top: 10px;
    font-style: italic;
  }

  .legend {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 100px;
    border: 1px solid currentColor;
  }
  .chip.core { color: #1a1a1a; }
  .chip.fail { color: #c45730; }
