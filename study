  body {
    background-image:
      radial-gradient(circle at 20% 10%, rgba(196, 87, 48, 0.08) 0%, transparent 40%),
      radial-gradient(circle at 80% 90%, rgba(45, 90, 75, 0.07) 0%, transparent 40%);
