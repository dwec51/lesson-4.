  }
  .sub-list strong { display: block; margin-bottom: 2px; }

  /* Type colors */
  .node[data-type="fail"] .num,
  .node[data-type="fail"] .toggle { color: #c45730; }
  .node[data-type="fix"] .num,
  .node[data-type="fix"] .toggle { color: #2d5a4b; }
  .node[data-type="fix"] .body-inner em { color: #2d5a4b; }
  .node[data-type="fix"] .key-box { border-left-color: #2d5a4b; }
  .node[data-type="fix"] .key-box .label { color: #2d5a4b; }

  footer {
    text-align: center;
    margin-top: 36px;
    padding-top: 20px;
    border-top: 1px solid rgba(26,26,26,0.15);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999;
  }

  .controls {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-bottom: 20px;
  }
  .btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 9px 16px;
    border-radius: 100px;
    border: 1px solid #1a1a1a;
    background: transparent;
    color: #1a1a1a;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .btn:active { background: #1a1a1a; color: #f5f1e8; }
